//@version=6
// ============================================================================
// ORB SYMMETRIC v4.1 MNQ — SYMBOL-LOCKED PAPER-TRADING BUILD
// Generated from orb_sym_v4.pine on 2026-07-16. Operational changes only:
//   • MNQ chart lock; M1 hard-disabled.
//   • current per-side commission = $0.91; one adverse tick/fill retained.
//   • early-close date-list guard defaults ON.
//   • normal session flat remains ~16:15 ET, before the current 16:45 deadline;
//     listed early-close flat remains ~12:45 ET, before the 12:59 deadline.
// Signal geometry matches corrected v4 with the same per-symbol settings.
// Static-audited locally; TradingView compile + known-half-day replay are required
// before alerts or paper-week observation. Research/advisory only; no automation.
// ============================================================================
// FROZEN CORRECTED-v4 SIGNAL SPEC
// Chart: MNQ continuous contract, 15-minute bars, America/New_York.
// OR: 09:30–10:00 ET. The first 15-minute close beyond either OR boundary
// from 10:00–16:00 locks the day. Entry is market-on-close in that direction.
// Stop: opposite OR boundary. Target: 1R. One decision maximum per session.
// Default sizing: floor($300 / one-contract stop risk), capped at 10 micros.
// M1 hard-disabled. Early-close dates are user-maintained and must be checked
// against the CME calendar roughly two weeks before each listed holiday.
// Display: LONG/SHORT marker plus exactly two four-candle TP/SL segments.
// Full validation record: HANDOFF.md and reports/geometry_correction_note.md.
// ============================================================================

strategy("ORB Symmetric v4.1 MNQ (15m NY, dyn size, early-close guard)",
     shorttitle = "ORB-SYM-v4.1-MNQ",
     overlay = true,
     process_orders_on_close = true,
     calc_on_every_tick = false,
     initial_capital = 50000,
     default_qty_type = strategy.fixed,
     default_qty_value = 1,
     commission_type = strategy.commission.cash_per_contract,
     commission_value = 0.91,   // $1.82 current round turn / 2; cash_per_contract charges entry and exit
     slippage = 1,              // 1 tick per fill
     margin_long = 0, margin_short = 0,  // no emulator margin check: every signal under the
                                         // budget must fill, exactly like the validated sim
     max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)
// NOTE on drawings: each entry creates only two fixed four-candle segments
// (TP and SL). TradingView keeps the most recent line objects up to the
// max_lines_count cap; LONG/SHORT plotshapes remain available through history.

// ---------------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------------
TZ = "America/New_York"

sizeMode = input.string("Dynamic $ budget", "Sizing mode",
     options = ["Dynamic $ budget", "Fixed contracts"],
     tooltip = "Frozen paper-control default: qty = floor($300 / (stop distance " +
               "x point value)), capped at 10 micros. Corrected-v4 research " +
               "supersedes the older headline economics. Fixed mode is a parity " +
               "fallback only. Do not tune sizing during paper weeks.")
riskBudgetUSD = input.float(300.0, "Dynamic: $ risk budget per trade", minval = 50,
     tooltip = "Per chart/leg. $300 is the ONLY budget that passed the " +
               "pre-registered gate ($400/$500/$575 all bust more than they " +
               "gain). Running BOTH symbols: worst-case both-legs-stopped day " +
               "~ -2x budget = -$600 vs the $1,250 DLL. Do NOT raise without " +
               "re-running the optimizer (reports/tweaks/).")
maxQty = input.int(10, "Dynamic: max contracts (micros)", minval = 1, maxval = 40,
     tooltip = "Hard ceiling on the dynamic quantity (Tradeify 50k allows 40 " +
               "micros; 10 is the validated cap). Binds only on very narrow ORs.")
qtyFixed = input.int(2, "Fixed: contracts (micros)", minval = 1, maxval = 5,
     tooltip = "Used only in Fixed mode — v1's Lightning-optimized default.")
maxRiskUSD = input.float(575.0, "Fixed: max $ risk per trade (skip wider days)", minval = 50,
     tooltip = "Used only in Fixed mode — v1's cap. In Dynamic mode the budget " +
               "itself is the cap (a day is skipped only if even 1 contract " +
               "risks more than the budget).")
// MNQ v4.1 operational split: M1 is hard-disabled. The registered MGC-only
// filter removes profitable MNQ trades, so no chart input can accidentally arm it.
useM1 = false
useEarlyFlat = input.bool(true, "Early-close guard — flat ~12:45 ET on listed dates (default ON)",
     tooltip = "Mechanizes the manual flat-by-12:55-ET rule for CME early-close " +
               "days (reports/b7_early_close_calendar.md): on a listed date, no " +
               "new entries from 12:30 ET and any open position is closed on the " +
               "12:30 ET bar (fill ~12:45, before the ~13:00 halt). Prevents the " +
               "B7 half-day carry — weekend carries VIOLATE Lightning rules. The " +
               "list is USER-MAINTAINED: verify each date on " +
               "cmegroup.com/trading-hours ~2 weeks ahead and keep this input " +
               "current. NOT TV-tested until bar-replayed on a known half-day.")
earlyCloseDates = input.string(
     "2026-09-07,2026-11-26,2026-11-27,2026-12-24,2027-01-18,2027-02-15,2027-05-31,2027-06-18,2027-07-05",
     "Early-close dates (YYYY-MM-DD, comma-separated)",
     tooltip = "Shipped default = the 12-month forward calendar in " +
               "reports/b7_early_close_calendar.md (early-close days only; full " +
               "closures print no bars and need no entry). Bold-risk dates " +
               "2026-11-27 / 2026-12-24 / 2027-06-18 are weekend-carry days.")
showPanel = input.bool(false, "Show diagnostic panel")

isDyn = sizeMode == "Dynamic $ budget"

// M1 frozen constant — NOT an input (0.10 / 0.25 tested and REFUTED; do not tune).
M1_FRAC = 0.05

// ---------------------------------------------------------------------------
// SESSION + OPENING RANGE (window-defined; no clock arithmetic)
// ---------------------------------------------------------------------------
inSess   = not na(time(timeframe.period, "0930-1600", TZ))
orActive = not na(time(timeframe.period, "0930-1000", TZ))
sessStart = inSess and not inSess[1]
sessEnd   = (not inSess) and inSess[1]

tfOK  = timeframe.isminutes and timeframe.multiplier == 15
isMNQ = str.contains(syminfo.ticker, "MNQ")
isMGC = not isMNQ and str.contains(syminfo.ticker, "MGC")
symOK = isMNQ
cfgOK = tfOK and symOK

// M1 is armed only when the user enables it AND the chart is MGC (the filter
// FAILS economics on MNQ — enforced here, not left to the user's memory).
m1Armed = false

// Early-close guard (v4): purely date-list driven — NO detection, no repaint
// surface. todayStr is built in NY time so the date match is session-correct.
tzM = month(time, TZ)
tzD = dayofmonth(time, TZ)
todayStr = str.tostring(year(time, TZ)) + "-" +
     (tzM < 10 ? "0" : "") + str.tostring(tzM) + "-" +
     (tzD < 10 ? "0" : "") + str.tostring(tzD)
earlyDay = useEarlyFlat and str.contains(earlyCloseDates, todayStr)
// True from the 12:30 ET bar onward on a listed day: blocks new entries and
// triggers the shared force-flat (order fills on this bar's close ~12:45 ET,
// ahead of the ~13:00 halt after which no 15m bars print).
earlyCut = earlyDay and not na(time(timeframe.period, "1230-1600", TZ))

var float orHi = na
var float orLo = na
var bool  orSeen = false
var bool  locked = false
var int nSessions = 0
var int nEntries = 0
var int nRiskSkips = 0
var int nM1Skips = 0

// Minimal display state. These reset on every bar and never affect orders.
bool tookLong = false
bool tookShort = false
const int VISUAL_LEVEL_BARS = 4

if sessStart
    orHi := na
    orLo := na
    orSeen := false
    locked := false
    nSessions += 1
if orActive
    orHi := na(orHi) ? high : math.max(orHi, high)
    orLo := na(orLo) ? low : math.min(orLo, low)
    orSeen := true

// OR is tradeable once the window has passed, this bar is still in-session,
// and the range is sane. No other conditions exist — by design.
orDone = inSess and not orActive and orSeen and not na(orHi) and orHi > orLo

// ---------------------------------------------------------------------------
// ONE-SHOT SYMMETRIC BREAKOUT (decision path identical to v2b when M1 is OFF;
// M1 adds exactly one skip-day condition on the first breakout bar's close)
// ---------------------------------------------------------------------------
canTrade  = orDone and not locked and cfgOK and strategy.position_size == 0 and not earlyCut
longBrk   = canTrade and close > orHi
shortBrk  = canTrade and close < orLo

if longBrk or shortBrk
    side    = longBrk ? 1 : -1
    entryPx = close
    riskPts = longBrk ? entryPx - orLo : orHi - entryPx
    // M1 margin test (close-basis, pure float, frozen 0.05 x OR-width; same
    // formula the scan validated). m1Pass is vacuously true when not armed.
    orW    = orHi - orLo
    m1Pass = not m1Armed or (longBrk ? entryPx > orHi + M1_FRAC * orW
                                     : entryPx < orLo - M1_FRAC * orW)
    risk1cUSD = riskPts * syminfo.pointvalue
    qtyDyn  = risk1cUSD > 0 ? math.min(maxQty, math.floor(riskBudgetUSD / risk1cUSD)) : 0
    qtyUse  = isDyn ? qtyDyn : qtyFixed
    riskUSD = risk1cUSD * qtyUse
    sizeOK  = isDyn ? qtyUse >= 1 : riskUSD <= maxRiskUSD
    if riskPts > 0 and qtyUse >= 1 and sizeOK and m1Pass
        stopPx = entryPx - side * riskPts
        tgtPx  = entryPx + side * riskPts
        if longBrk
            strategy.entry("L", strategy.long, qty = qtyUse, comment = "OR-break long")
            strategy.exit("Lx", "L", stop = stopPx, limit = tgtPx)
        else
            strategy.entry("S", strategy.short, qty = qtyUse, comment = "OR-break short")
            strategy.exit("Sx", "S", stop = stopPx, limit = tgtPx)
        // ---- minimal visual layer (display only, no order logic) ----
        tookLong := longBrk
        tookShort := shortBrk
        line.new(bar_index, stopPx, bar_index + VISUAL_LEVEL_BARS, stopPx,
             color = color.new(color.red, 0), style = line.style_solid,
             width = 2, extend = extend.none)
        line.new(bar_index, tgtPx, bar_index + VISUAL_LEVEL_BARS, tgtPx,
             color = color.new(color.green, 0), style = line.style_solid,
             width = 2, extend = extend.none)
        nEntries += 1
        alert("ORB-SYM v4.1 MNQ " + (longBrk ? "LONG " : "SHORT ") + syminfo.ticker +
              " qty=" + str.tostring(qtyUse) + (isDyn ? " (dyn)" : " (fixed)") +
              " entry~" + str.tostring(entryPx, format.mintick) +
              " SL=" + str.tostring(stopPx, format.mintick) +
              " TP=" + str.tostring(tgtPx, format.mintick) +
              " risk$~" + str.tostring(riskUSD, "#") +
              " (signal = confirmed 15m close; fills lag)",
              alert.freq_once_per_bar_close)
    else
        if not m1Pass
            nM1Skips += 1
        else
            nRiskSkips += 1
    // ANY first breakout locks the day — including M1-skipped and risk-skipped
    // ones — matching the validated one-decision-per-day simulation exactly.
    locked := true

// Force-flat: session end (pre-B7 mechanism — see orb_sym_v1 header KNOWN
// OPEN ITEMS) OR the v4 early-close guard (first bar at/after 12:30 ET on a
// listed date; no-op afterwards once flat). ONE close_all call, shared.
if (sessEnd or earlyCut) and strategy.position_size != 0
    strategy.close_all(comment = earlyCut ? "early-close flat" : "session flat")

// ---------------------------------------------------------------------------
// MINIMAL VISUALS + OPTIONAL PANEL
// ---------------------------------------------------------------------------
plotshape(tookLong, "Long signal", style = shape.labelup,
     location = location.belowbar, color = color.new(color.green, 0),
     size = size.small, text = "LONG", textcolor = color.white)
plotshape(tookShort, "Short signal", style = shape.labeldown,
     location = location.abovebar, color = color.new(color.red, 0),
     size = size.small, text = "SHORT", textcolor = color.white)

var table pnl = table.new(position.top_right, 2, 8, border_width = 1)
if showPanel and barstate.islast
    table.cell(pnl, 0, 0, "Config"), table.cell(pnl, 1, 0,
         (tfOK ? "15m OK" : "WRONG TF — NEED 15m") + " / " +
         (isMNQ ? "MNQ" : isMGC ? "MGC" : "UNSUPPORTED SYMBOL"),
         text_color = cfgOK ? color.gray : color.red,
         bgcolor = cfgOK ? na : color.new(color.red, 80))
    table.cell(pnl, 0, 1, "Sizing"), table.cell(pnl, 1, 1,
         isDyn ? "DYNAMIC $" + str.tostring(riskBudgetUSD, "#") + "/trade, max " +
              str.tostring(maxQty) + "ct" :
              "FIXED " + str.tostring(qtyFixed) + "ct, cap $" + str.tostring(maxRiskUSD, "#"))
    table.cell(pnl, 0, 2, "M1 margin skip"), table.cell(pnl, 1, 2,
         m1Armed ? "ON (MGC, 0.05 x OR-width)" :
         useM1 ? "IGNORED — MGC only (refuted on this symbol)" : "OFF (default)",
         text_color = useM1 and not m1Armed ? color.orange : color.gray)
    table.cell(pnl, 0, 3, "Status"), table.cell(pnl, 1, 3,
         not cfgOK ? "CONFIG ERROR — NO TRADES WILL FIRE" :
         locked ? "LOCKED (day done)" : orDone ? "ARMED" : orActive ? "OR FORMING" : "OFF-SESSION",
         text_color = cfgOK ? color.gray : color.red)
    table.cell(pnl, 0, 4, "Sessions / entries / risk-skips / M1-skips"),
         table.cell(pnl, 1, 4, str.tostring(nSessions) + " / " + str.tostring(nEntries) + " / " +
              str.tostring(nRiskSkips) + " / " + str.tostring(nM1Skips))
    table.cell(pnl, 0, 5, "Entry rate (expect ~0.7/session)"),
         table.cell(pnl, 1, 5, nSessions > 0 ? str.tostring(nEntries / float(nSessions), "#.##") : "-")
    table.cell(pnl, 0, 6, "Early-close guard"), table.cell(pnl, 1, 6,
         not useEarlyFlat ? "OFF — manual early-close control required" :
         earlyDay ? "⚠ TODAY IS LISTED — flat from ~12:45 ET" : "ON (date list armed)",
         text_color = useEarlyFlat and earlyDay ? color.orange : color.gray)
    table.cell(pnl, 0, 7, "Net profit"),
         table.cell(pnl, 1, 7, str.tostring(strategy.netprofit, "#.##"),
         text_color = strategy.netprofit >= 0 ? color.green : color.red)
